# Copy this file to .env.local for local development (never commit .env.local).
#
# Client-side (Vite) env vars. These must be prefixed VITE_ to be exposed to
# the browser bundle. Populated automatically in .env.local by `npx convex dev`
# on first run against a Convex deployment.

# Convex deployment URL used by the browser/SSR client (src/router.tsx).
VITE_CONVEX_URL=

# Convex HTTP actions URL (auth well-known endpoints, etc). Also written by
# `npx convex dev`.
VITE_CONVEX_SITE_URL=

# Set by `npx convex dev` / `npx convex deploy` to record which deployment
# this project is linked to. Not read directly by application code.
CONVEX_DEPLOYMENT=

# -----------------------------------------------------------------------------
# NOT set here -- these are server-side Convex deployment env vars, configured
# via `npx convex env set <NAME> <VALUE>` or the Convex dashboard, not in this
# file or .env.local. They are read from process.env inside convex/ functions.
#
#   RESEND_API_KEY   convex/email.ts -- enables live transactional email
#                    (confirmation / waitlist / claim). Unset = emails are a
#                    no-op (safe for dev, tests, and previews).
#   APP_URL          convex/email.ts, convex/waitlist.ts -- base URL used to
#                    build links inside emails (e.g. APP_URL/claim/<token>).
#   JWT_PRIVATE_KEY  Convex Auth signing key, generated by
#   JWKS              `npx @convex-dev/auth`. Required for live sign-in;
#                    without them, auth is deferred/non-functional.
# -----------------------------------------------------------------------------
